# ═══ Supabase ═══
# Supabase loyihangiz Settings → API sahifasidan oling
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Service role key — XAVFLI! Hech qachon brauzerga yubormang.
# Faqat server-side API'da (app/api/*) ishlatiladi. Vercel Env'da qo'shing.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ═══ JWT ═══
# Sessiya cookie imzosi uchun. Random 32+ belgili string.
# Yaratish: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_LONG_RANDOM_SECRET_HERE_32_PLUS_CHARS
